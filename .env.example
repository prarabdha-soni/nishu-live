# Serverless (Vercel) mode — Supabase Realtime carries the auction.
# Copy to .env.local for local testing; set the same two vars in Vercel → Project → Environment Variables.
VITE_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=YOUR-ANON-PUBLIC-KEY

# Optional: point the client at a self-hosted Socket.IO auction server instead
# (leave unset on Vercel; used automatically in local dev on :8787)
# VITE_SOCKET_URL=http://localhost:8787
